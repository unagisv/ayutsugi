{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(./gradlew build)",
      "Bash(./gradlew test)",
      "Bash(./gradlew test *)",
      "Bash(./gradlew lint)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)"
    ],
    "ask": [
      "Write",
      "Edit",
      "Bash(git commit *)",
      "Bash(git add *)"
    ],
    "deny": [
      "Bash(git push *)",
      "Bash(rm -rf *)",
      "Read(./local.properties)",
      "Read(./**/*.keystore)",
      "Read(./**/*.jks)"
    ]
  }
}
